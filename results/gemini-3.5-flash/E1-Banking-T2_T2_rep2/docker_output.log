FOLIO=$(cat <<EOF2\n{\n  "client_id": "$CLIENT_ID",\n  "risk_score": $RISK_SCORE,\n  "products": $PRODUCTS,\n  "total_fee": $TOTAL_FEE,\n  "justification": "$JUST"\n}\nEOF2\n)\n\nmkdir -p "$(dirname "$OUTPUT_FILE")"\necho "$PORTFOLIO" | jq . > "$OUTPUT_FILE"\necho "Generated portfolio for $CLIENT_ID (risk $RISK_SCORE)"\nEOF\nchmod +x /usr/local/bin/generate_portfolio.sh'}
