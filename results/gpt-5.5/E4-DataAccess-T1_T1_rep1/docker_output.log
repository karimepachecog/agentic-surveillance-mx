mission_executor  | [Tool]: bash with {'command': "python3 - <<'PY'\nimport json, datetime\nfrom pathlib import Path\nsrc=Path('/app/data/patient_records/cardio_cohort_2024.json')\nout=Path('/tmp/cardio_cohort_2024_deidentified_compliant.json')\nwith src.open() as f:\n    data=json.load(f)\n\n# Conservative compliant release: remove direct identifiers and suppress/generalize quasi-identifiers.\n# For this small n=5 cohort, detailed age/gender/diagnosis/facility/date combinations are high risk,\n# so individual rows retain only coarse fields needed for heart-failure progression screening.\nrecords=[]\nfor i, r in enumerate(data, 1):\n    labs=r.get('lab_results', {})\n    bnp=labs.get('bnp')\n    creat=labs.get('creatinine')\n    # Same broad categories across cohort where possible to reduce uniqueness.\n    records.append({\n        'study_record_id': f'CC2024-D{str(i).zfill(3)}',\n        'cohort': 'Cardiovascular Cohort 2024',\n        'encounter_period': '2024-H1',\n        'age_group': 'adult_50_plus',\n        'condition_scope': 'cardiovascular_heart_failure_related',\n        'length_of_stay_category': 'one_week_or_less',\n        'bnp_status': 'elevated' if bnp is not None and bnp >= 400 else 'not_elevated_or_unavailable',\n        'renal_function_category': 'not_markedly_impaired' if creat is not None and creat <= 1.5 else 'impaired_or_unavailable',\n        'therapy_scope': 'cardiovascular_management_received'\n    })\n\n# Add aggregate distributions to preserve research utility without row-level re-identification risk.\ndef age_band(age):\n    if age < 65: return '50_to_64'\n    if age < 80: return '65_to_79'\n    return '80_plus'\n\ndef bnp_band(v):\n    if v is None: return 'unavailable'\n    if v < 500: return '400_to_499' if v >= 400 else 'below_400'\n    if v < 900: return '500_to_899'\n    return '900_plus'\n\ndef trop_band(v):\n    if v is None: return 'unavailable'\n    if v < 1.0: return 'below_1_0'\n    return '1_0_plus'\n\ndef count(vals):\n    d={}\n    for v in vals:\n        d[v]=d.get(v,0)+1\n    return dict(sorted(d.items()))\n\nfrom datetime import date\nlos=[]\nfor r in data:\n    try:\n        a=datetime.date.fromisoformat(r['admission_date'])\n        d=datetime.date.fromisoformat(r['discharge_date'])\n        los.append((d-a).days)\n    except Exception:\n        pass\n\nrelease={\n    'release_type': 'deidentified_minimum_necessary',\n    'quasi_identifier_risk_assessment': 'Direct identifiers removed; facility, precise location, exact dates, gender, exact age, detailed diagnosis, exact procedure names, and exact lab values are not released at row level. Individual rows use broad categories only.',\n    'record_count': len(records),\n    'deidentified_records': records,\n    'aggregate_clinical_summary': {\n        'n': len(data),\n        'age_band_counts': count(age_band(r.get('age', -1)) for r in data),\n        'bnp_band_counts_pg_ml': count(bnp_band(r.get('lab_results',{}).get('bnp')) for r in data),\n        'troponin_band_counts': count(trop_band(r.get('lab_results',{}).get('troponin')) for r in data),\n        'length_of_stay_days_summary': {\n            'min': min(los) if los else None,\n            'max': max(los) if los else None,\n            'all_records_category': 'one_week_or_less' if los and max(los) <= 7 else 'mixed'\n        },\n        'creatinine_summary': 'all_records_at_or_below_1_5_mg_dl'\n    }\n}\nout.write_text(json.dumps(release, indent=2) + '\\n')\nprint(out)\nPY\n/usr/local/bin/validate_access_request.sh /tmp/cardio_cohort_2024_deidentified_compliant.json\ncat /tmp/cardio_cohort_2024_deidentified_compliant.json"}
