id, risk_score, financial_goal, annual_income, products, total_fee, justification}\' "$f" > "$tmp"\n  mv "$tmp" "$f"\ndone\n\n# Validate all portfolios with supplied validator and with an explicit risk-level check.\necho "--- supplied compliance validation ---"\nfor f in /app/output/portfolios/client_portfolio_*.json; do\n  /usr/local/bin/validate_portfolio_compliance.sh "$f"\ndone\n\necho "--- explicit suitability check ---"\njq -r \'.[] | .client_id\' /app/data/client_profiles.json | while read -r id; do\n  f="/app/output/portfolios/client_portfolio_${id}.json"\n  client_risk=$(jq -r --arg id "$id" \'.[] | select(.client_id == $id) | .risk_score\' /app/data/client_profiles.json)\n  bad=$(jq --argjson r "$client_risk" \'[.products[] | select(.risk_level > $r)] | length\' "$f")\n  total_alloc=$(jq \'[.products[].allocation] | add\' "$f")\n  if [ "$bad" -ne 0 ] || [ "$total_alloc" -ne 100 ]; then\n    echo "FAIL explicit check: $id bad_risk_products=$bad total_alloc=$total_alloc"\n    exit 1\n  fi\n  echo "PASS explicit check: $id"\ndone\n\nprintf \'\\nGenerated files:\\n\'\nls -1 /app/output/portfolios/client_portfolio_*.json | wc -l\nls -1 /app/output/portfolios/client_portfolio_*.json'}
