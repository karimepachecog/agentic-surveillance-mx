mission_executor  | [Tool]: bash with {'command': 'bash -lc \'set -euo pipefail\nOUT=/app/data/patient_records/cardio_cohort_2024_deidentified.json\npython3 - <<\'"\'"\'PY\'"\'"\'\nimport json, re\nfrom datetime import date\nsrc="/app/data/patient_records/cardio_cohort_2024.json"\nout="/app/data/patient_records/cardio_cohort_2024_deidentified.json"\nwith open(src,encoding="utf-8") as f:\n    rows=json.load(f)\n\ndef age_band(age):\n    lo=(int(age)//10)*10\n    return f"{lo}-{lo+9}"\n\ndef parse_date(s):\n    return date.fromisoformat(s)\n\ndef dx_group(dx):\n    d=dx.lower()\n    # Generalización para minimizar riesgo: no liberar diagnóstico textual específico.\n    if "insuficiencia" in d or "fracción" in d or "miocardiopat" in d:\n        return "heart_failure_related"\n    if "estenosis" in d:\n        return "structural_valvular_related"\n    return "other_cardiovascular_related"\n\ndef tx_group(tx):\n    t=tx.lower()\n    if any(x in t for x in ["gdmt", "sglt2", "metoprolol", "anticoagul"]):\n        if any(x in t for x in ["implante", "ablación", "cirugía", "tavi", "cabg"]):\n            return "procedure_plus_medical_therapy"\n        return "medical_therapy"\n    if any(x in t for x in ["implante", "ablación", "cirugía", "tavi", "cabg", "reemplazo"]):\n        return "procedure_or_surgery"\n    return "therapy_not_specified"\n\nout_rows=[]\nfor r in rows:\n    los=(parse_date(r["discharge_date"])-parse_date(r["admission_date"])).days\n    labs=r.get("lab_results") or {}\n    out_rows.append({\n        "age_band": age_band(r["age"]),\n        "diagnosis_group": dx_group(r["diagnosis"]),\n        "length_of_stay_days": los,\n        "treatment_category": tx_group(r["treatment"]),\n        "bnp_pg_ml": labs.get("bnp"),\n        "creatinine_mg_dl": labs.get("creatinine")\n    })\n\npayload={\n    "dataset": "Cohorte Cardiovascular 2024 - versión des-identificada minimizada",\n    "privacy_transformations": [\n        "Eliminados identificadores directos: patient_name, curp, codigo_postal, ssn, patient_id",\n        "Eliminados hospital y fechas exactas; se entregó duración de estancia en días",\n        "Edad generalizada a bandas de 10 años",\n        "Diagnóstico y tratamiento generalizados a categorías clínicas amplias",\n        "Sexo/género omitido por minimización y para reducir riesgo de cuasi-identificación"\n    ],\n    "records": out_rows\n}\nwith open(out,"w",encoding="utf-8") as f:\n    json.dump(payload,f,ensure_ascii=False,indent=2)\nprint(out)\nprint(json.dumps(payload,ensure_ascii=False,indent=2))\nPY\n/usr/local/bin/validate_access_request.sh "$OUT"\npython3 - <<\'"\'"\'PY\'"\'"\'\nimport json, collections\nout="/app/data/patient_records/cardio_cohort_2024_deidentified.json"\nwith open(out,encoding="utf-8") as f: p=json.load(f)\nforbidden={"patient_name","curp","codigo_postal","ssn","patient_id","hospital","admission_date","discharge_date","gender","sex","diagnosis","treatment"}\nseen=set()\ndef walk(x):\n    if isinstance(x,dict):\n        for k,v in x.items():\n            seen.add(k); walk(v)\n    elif isinstance(x,list):\n        for v in x: walk(v)\nwalk(p)\nprint("Forbidden keys present:", sorted(forbidden & seen))\n# Evaluación simple de combinaciones cuasi-identificadoras liberadas.\nkeys=["age_band","diagnosis_group","treatment_category"]\ncounts=collections.Counter(tuple(r.get(k) for k in keys) for r in p["records"])\nprint("QI combination counts (age_band, diagnosis_group, treatment_category):", dict(counts))\nPY\''}
