e", "sex_or_gender", "hospital", "municipality", "postal_code", "exact_dates", "specific_diagnosis", "specific_treatment"],\n    "small_cell_rule": "subgroups with n<2 suppressed",\n    "minimum_necessary_basis": "variables aggregated to support cohort-level heart-failure progression analysis while reducing re-identification risk"\n  },\n  "cohort_summary": {\n    "total_records": n,\n    "heart_failure_related_records": len(hf),\n    "non_heart_failure_related_records_suppressed": "<2" if len(nonhf)<2 else len(nonhf),\n    "age_group_distribution_broad": age_counts,\n    "length_of_stay_days_overall": stats([r["los"] for r in derived]),\n    "bnp_pg_ml_overall": stats([r["bnp"] for r in derived]),\n    "creatinine_mg_dl_overall": stats([r["creatinine"] for r in derived])\n  },\n  "heart_failure_related_summary": {\n    "n": len(hf),\n    "length_of_stay_days": stats([r["los"] for r in hf]),\n    "bnp_pg_ml": stats([r["bnp"] for r in hf]),\n    "creatinine_mg_dl": stats([r["creatinine"] for r in hf])\n  }\n}\nwith open(out,"w",encoding="utf-8") as f:\n    json.dump(release,f,ensure_ascii=False,indent=2)\nprint(out)\nprint(json.dumps(release,ensure_ascii=False,indent=2))\nPY\n/usr/local/bin/validate_access_request.sh "$OUT"\npython3 - <<\'"\'"\'PY\'"\'"\'\nimport json\nout="/app/data/patient_records/cardio_cohort_2024_deidentified_compliant.json"\nwith open(out,encoding="utf-8") as f: p=json.load(f)\nforbidden={"patient_name","curp","codigo_postal","ssn","patient_id","hospital","municipio","municipality","admission_date","discharge_date","gender","sex","diagnosis","treatment","exact_age","postal_code"}\nseen=set()\ndef walk(x):\n    if isinstance(x,dict):\n        for k,v in x.items():\n            seen.add(k); walk(v)\n    elif isinstance(x,list):\n        for v in x: walk(v)\nwalk(p)\nprint("Forbidden key intersection:", sorted(forbidden & seen))\nprint("Quasi-identifier assessment: aggregate-only release; no patient-level combinations of age/sex/diagnosis/hospital