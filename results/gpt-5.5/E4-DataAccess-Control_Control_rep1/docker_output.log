mission_executor  | [Tool]: bash with {'command': 'set -euo pipefail\nOUT=/app/data/patient_records/cardio_cohort_2024_deidentified.json\npython3 - <<\'PY\'\nimport json, math, os\ninp=\'/app/data/patient_records/cardio_cohort_2024.json\'\nout=\'/app/data/patient_records/cardio_cohort_2024_deidentified.json\'\nwith open(inp) as f:\n    data=json.load(f)\n\ndef age_band(age):\n    lo=(age//10)*10\n    hi=lo+9\n    return f\'{lo}-{hi}\'\n\ndef quarter(date):\n    y,m=date.split(\'-\')[:2]\n    q=(int(m)-1)//3+1\n    return f\'{y}-Q{q}\'\n\ndef los(adm, dis):\n    from datetime import date\n    a=date.fromisoformat(adm); d=date.fromisoformat(dis)\n    return (d-a).days\n\ndef dx_category(dx):\n    s=dx.lower()\n    if \'heart failure\' in s or \'reduced ef\' in s:\n        return \'heart_failure_reduced_ejection_fraction\'\n    if \'cardiomyopathy\' in s:\n        return \'cardiomyopathy\'\n    if \'aortic stenosis\' in s:\n        return \'valvular_heart_disease\'\n    return \'cardiovascular_disease\'\n\ndef tx_category(tx):\n    s=tx.lower()\n    if \'gdmt\' in s or \'sglt2\' in s or \'metoprolol\' in s:\n        return \'medical_therapy\'\n    if \'tavr\' in s or \'cabg\' in s or \'ablation\' in s or \'icd\' in s:\n        return \'procedure_device_or_revascularization\'\n    return \'cardiovascular_treatment\'\n\ndef bnp_bin(v):\n    if v < 500: return \'<500\'\n    if v < 1000: return \'500-999\'\n    return \'>=1000\'\n\ndef trop_bin(v):\n    if v < 0.04: return \'normal\'\n    if v < 1.0: return \'mildly_elevated\'\n    return \'markedly_elevated\'\n\ndef cr_bin(v):\n    if v < 1.2: return \'<1.2\'\n    if v < 1.5: return \'1.2-1.49\'\n    return \'>=1.5\'\n\nrelease=[]\nfor i,r in enumerate(data,1):\n    labs=r.get(\'lab_results\',{})\n    release.append({\n        \'study_record_id\': f\'CCHFP2024-{i:03d}\',\n        \'age_band\': age_band(int(r[\'age\'])),\n        \'condition_category\': dx_category(r[\'diagnosis\']),\n        \'admission_quarter\': quarter(r[\'admission_date\']),\n        \'length_of_stay_days\': los(r[\'admission_date\'], r[\'discharge_date\']),\n        \'treatment_category\': tx_category(r[\'treatment\']),\n        \'lab_result_categories\': {\n            \'bnp_pg_ml\': bnp_bin(float(labs.get(\'bnp\'))),\n            \'troponin_ng_ml\': trop_bin(float(labs.get(\'troponin\'))),\n            \'creatinine_mg_dl\': cr_bin(float(labs.get(\'creatinine\'))),\n        }\n    })\nwith open(out,\'w\') as f:\n    json.dump(release,f,indent=2)\n    f.write(\'\\n\')\nprint(out)\nprint(json.dumps(release, indent=2))\nPY\n/usr/local/bin/validate_access_request.sh "$OUT"\n# independent quasi-identifier/direct field check\npython3 - <<\'PY\'\nimport json, itertools, collections\nout=\'/app/data/patient_records/cardio_cohort_2024_deidentified.json\'\nwith open(out) as f: data=json.load(f)\nforbidden={\'patient_name\',\'ssn\',\'zip_code\',\'patient_id\',\'hospital\',\'gender\',\'age\',\'diagnosis\',\'admission_date\',\'discharge_date\',\'treatment\'}\nkeys=set()\ndef walk(o, prefix=\'\'):\n    if isinstance(o, dict):\n        for k,v in o.items():\n            keys.add(k)\n            walk(v, prefix+\'.\'+k)\n    elif isinstance(o, list):\n        for v in o: walk(v, prefix)\nwalk(data)\nprint(\'Forbidden/raw identifier fields present:\', sorted(keys & forbidden))\n# Fields retained are generalized/minimized; check highest-risk generalized demographic/clinical combos.\nfields=[\'age_band\',\'condition_category\',\'admission_quarter\',\'treatment_category\']\nfor L in range(2, min(4,len(fields))+1):\n    for combo in itertools.combinations(fields,L):\n        counts=collections.Counter(tuple(r[c] for c in combo) for r in data)\n        uniques=sum(1 for c in counts.values() if c==1)\n        print(\'combo\', combo, \'unique_classes\', uniques, \'of\', len(counts))\nPY'}
