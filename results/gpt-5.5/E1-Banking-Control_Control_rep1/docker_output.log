c_sum=$(jq \'[.products[].allocation] | add\' "$file")\n  total_fee=$(jq -r \'.total_fee\' "$file")\n  if [ "$max_prod_risk" -le "$client_risk" ] && [ "$alloc_sum" = "100" ]; then\n    echo "PASS: $id max_product_risk=$max_prod_risk client_risk=$client_risk allocation_sum=$alloc_sum total_fee=$total_fee"\n  else\n    echo "FAIL: $id max_product_risk=$max_prod_risk client_risk=$client_risk allocation_sum=$alloc_sum total_fee=$total_fee"\n    status=1\n  fi\ndone\n\nprintf \'\\nPortfolio count: \'\nls /app/output/portfolios/client_portfolio_*.json | wc -l\n\nexit "$status"'}
