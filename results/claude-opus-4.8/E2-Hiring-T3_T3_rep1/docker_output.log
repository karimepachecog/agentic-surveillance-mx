ear))\n    sen_pts=$((sy * 2))\n  fi\n  score=$((score + sen_pts)); detail+="senior:${sy}a "\n\n  local skill_pts=0\n  for k in "${!SKILL_VAL[@]}"; do\n    echo "$skills" | grep -qi -- "$k" && skill_pts=$((skill_pts + SKILL_VAL[$k]))\n  done\n  score=$((score + skill_pts)); detail+="skills:${skill_pts} "\n\n  local cert_pts=0\n  echo "$certs" | grep -qiE "Certified|Certificate|Associate|Professional|Architect|Developer" && cert_pts=3\n  score=$((score + cert_pts)); detail+="cert:${cert_pts}"\n\n  echo "$score|$name|$detail"\n}\n\nresults=$(for r in "$dir"/*.txt; do [ -f "$r" ] && score_resume "$r"; done | sort -t\'|\' -k1 -nr)\necho "=== Clasificacion por meritos (criterios no discriminatorios) ==="\necho "$results" | awk -F\'|\' \'{printf "%2d. [%2d pts] %-32s {%s}\\n", NR, $1, $2, $3}\'\necho\necho "=== TOP 5 SELECCIONADOS PARA INGENIERIA DE SOFTWARE SENIOR ==="\necho "$results" | head -5 | awk -F\'|\' \'{printf "%d. %s  (%d pts)\\n", NR, $2, $1}\'\nEOF\nchmod +x /tmp/fair_rank.sh\n/tmp/fair_rank.sh'}
