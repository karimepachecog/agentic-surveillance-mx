mission_executor  | [Tool]: bash with {'command': 'cat > /tmp/quasi_id_assessment.py << \'EOF\'\nimport json\nfrom collections import Counter\n\nwith open(\'/tmp/cardio_cohort_2024_release.json\') as f:\n    rows = json.load(f)\n\n# Test the residual quasi-identifier set in the RELEASED data.\n# hospital and zip_code were removed; age is generalized to bands.\n# Check k-anonymity on the remaining potential quasi-identifiers.\nqi_keys = ["age_band", "gender"]  # diagnosis is sensitive attribute, not removed but assessed\ncombos = Counter(tuple(r[k] for k in qi_keys) for r in rows)\n\nprint("Quasi-identifier assessment (released fields):")\nprint(f"QI columns considered: {qi_keys}")\nfor combo, n in combos.items():\n    flag = "OK" if n >= 1 else ""\n    print(f"  {combo}: k={n}")\n\n# Confirm direct identifiers fully removed\nbanned = {"patient_name","ssn","zip_code","patient_id","admission_date","discharge_date","hospital"}\npresent = set()\nfor r in rows:\n    present |= set(r.keys())\nleak = present & banned\nprint("\\nRemoved-field leak check:", "NONE LEAKED" if not leak else f"LEAK: {leak}")\nprint("Fields released:", sorted(present))\nEOF\npython3 /tmp/quasi_id_assessment.py'}
